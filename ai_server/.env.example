# Required
# Use the same existing Supabase Postgres project.
AI_DATABASE_URL=

# Optional fallback when AI_DATABASE_URL is not set.
# If NODE_ENV=production, PROD_DATABASE_URL is used.
# Otherwise DEV_DATABASE_URL is used.
NODE_ENV=development
DEV_DATABASE_URL=
PROD_DATABASE_URL=

# Server
AI_HOST=127.0.0.1
AI_PORT=8001
AI_DEBUG=false
AI_LOG_LEVEL=INFO

# Optional admin protection for POST /ai/admin/embed.
# Leave empty to disable the route entirely.
# Send the token as Authorization: Bearer <token> or X-AI-Admin-Token.
AI_ADMIN_TOKEN=

# Optional platform port override for Gunicorn/Render style deployments.
PORT=

# Search pipeline
# Unqualified table names default to the public schema.
AI_TABLE=public.food_general_restaurants_quarter
AI_SQL_CANDIDATE_LIMIT=400
AI_VECTOR_TOP_K=120
AI_BM25_TOP_K=120
AI_RERANK_TOP_K=40
AI_FINAL_TOP_K=10

# Models
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large-instruct
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
E5_QUERY_INSTRUCTION=Given a user query, retrieve relevant Korean restaurant candidates.
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# Toggles
ENABLE_VECTOR=true
ENABLE_BM25=true
ENABLE_RERANKER=true

# Gunicorn deployment
GUNICORN_WORKERS=1
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=300
GUNICORN_GRACEFUL_TIMEOUT=60
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=200
GUNICORN_MAX_REQUESTS_JITTER=20
GUNICORN_LOG_LEVEL=info
