{
  "scripts": {
    "start": "npm run dev:proxy",
    "dev:proxy": "concurrently \"npm start --prefix backend\" \"npm start --prefix frontend\"",
    "dev:split": "npm run dev:proxy",
    "dev:same-origin:build": "npm run build:same-origin --prefix frontend",
    "dev:same-origin:serve": "concurrently \"npm run build:watch:same-origin --prefix frontend\" \"npm start --prefix backend\"",
    "dev:same-origin": "run-s dev:same-origin:build dev:same-origin:serve",
    "dev:mobile": "npm run dev:same-origin",
    "mobile:url": "node scripts/print-local-urls.mjs 3000",
    "mobile:url:auth": "node scripts/print-local-urls.mjs 5500",
    "build": "npm run build --prefix frontend",
    "lint:backend": "npm run lint --prefix backend",
    "lint:frontend": "npm run lint --prefix frontend",
    "lint": "run-s lint:backend lint:frontend",
    "test:backend": "npm test --prefix backend",
    "test:frontend": "npm run test:ci --prefix frontend",
    "test": "run-s test:backend test:frontend",
    "start:prod": "npm start --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "npm-run-all": "^4.1.5"
  }
}
