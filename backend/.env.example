GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=

# Optional app port for cloud platforms such as Render.
# PORT=5500

# Public backend origin used when building image and place-photo URLs.
# Example: https://your-backend.onrender.com
# API_PUBLIC_ORIGIN=
DEV_DATABASE_URL=postgresql://postgres.[your-dev-project-ref]:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres
DEV_SUPABASE_URL=https://your-dev-project-ref.supabase.co
DEV_SUPABASE_PUBLISHABLE_KEY=
PROD_DATABASE_URL=postgresql://postgres.[your-prod-project-ref]:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres
PROD_SUPABASE_URL=https://your-prod-project-ref.supabase.co
PROD_SUPABASE_PUBLISHABLE_KEY=

# Optional: custom CA bundle (inline PEM with \n escapes) or file path for TLS verification.
# DB_SSL_CA=
# DB_SSL_CA_FILE=
#
# Optional: set to disable for local Postgres without TLS.
# DB_SSL=disable
