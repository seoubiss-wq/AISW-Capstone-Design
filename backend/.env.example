GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=

# Optional AI Flask search server. Supports DEV_/PROD_ split like the DB envs.
# Example: http://127.0.0.1:8001
AI_SERVER_URL=
# DEV_AI_SERVER_URL=
# PROD_AI_SERVER_URL=
# AI_SERVER_TIMEOUT_MS=8000

# Optional app port for cloud platforms such as Render.
# PORT=5500

# Supabase Postgres direct or pooled connection string.
# Example: postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# Public backend origin used when building image and place-photo URLs.
# Example: https://your-backend.onrender.com
# API_PUBLIC_ORIGIN=

# Optional aliases if you prefer a Supabase-specific name.
# SUPABASE_DB_URL=
# SUPABASE_DATABASE_URL=
# DEV/PROD split naming examples.
DEV_SUPABASE_URL=https://your-dev-project-ref.supabase.co
DEV_SUPABASE_PUBLISHABLE_KEY=
PROD_SUPABASE_URL=https://your-prod-project-ref.supabase.co
PROD_SUPABASE_PUBLISHABLE_KEY=

# Optional: custom CA bundle (inline PEM with \n escapes) or file path for TLS verification.
# DB_SSL_CA=
# DB_SSL_CA_FILE=
#
# Optional: set to disable for local Postgres without TLS.
# DB_SSL=disable
